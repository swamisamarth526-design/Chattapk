# Environment (development or production)
NODE_ENV=development

# Server Port
# Railway will set this automatically
PORT=5000

# MongoDB Connection
# For local development
MONGODB_URI=mongodb://localhost:27017/chatx
# For Railway MongoDB add-on, set in Railway dashboard

# JWT Secret
# IMPORTANT: Generate a strong random string for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars

# JWT Expiration
JWT_EXPIRE=7d

# CORS Configuration (comma-separated)
# For development with local React frontend
FRONTEND_URL=http://localhost:5173
# For multiple origins
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# Socket.IO Configuration
# In production, frontend is served from same origin, so CORS relaxed
# In development, specify frontend URL


# Node Environment
NODE_ENV=development

# Frontend URL(s) allowed by CORS. For multiple origins, use comma-separated values.
FRONTEND_URL=http://localhost:5173
