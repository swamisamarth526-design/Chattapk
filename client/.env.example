# Development Environment Variables
# These are used by Vite during development and build

# API Server URL
# In production: frontend and backend are served from same domain, so use relative path /api
# In development: points to Node.js server (Vite proxy forwards to it)
VITE_API_URL=http://localhost:5000/api

# Socket.IO Server URL
# In production: frontend and backend are served from same domain
# In development: points to Node.js server with Socket.IO
VITE_SOCKET_URL=http://localhost:5000

# Optional: Application settings
# VITE_APP_NAME=ChatX
# VITE_APP_VERSION=1.0.0

